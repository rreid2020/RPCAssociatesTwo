# Copy to .env and fill in. Used by: node server.js  (not Vite)
#
# Step-by-step (DO Spaces, CORS, deploy): see PORTAL_FILE_STORAGE_SETUP.md in this folder.
#
# ══ Database ══
DB_HOST=localhost
DB_PORT=5432
DB_NAME=your_db
DB_USER=your_user
DB_PASSWORD=your_password
# Use "true" for DigitalOcean Managed PG (SSL)
DB_SSL=false
#
# ══ Email (leads / contact) ══
# RESEND_API_KEY=re_...
# EMAIL_FROM=...
# NOTIFICATION_EMAIL=info@example.com
#
# ══ Client portal: Clerk (required in production) ══
# Get from https://dashboard.clerk.com — must match the frontend’s Clerk app.
# CLERK_SECRET_KEY=sk_test_... or sk_live_...
#
# CORS: comma-separated list of site origins the browser will call this API from, e.g.
# ALLOWED_ORIGINS=https://axiomft.ca,https://www.axiomft.ca,https://portal.axiomft.ca,http://localhost:5173
#
# ══ File repository: DigitalOcean Spaces (S3-compatible) ══
# Without all four, POST /v1/files/presign-put returns 503 and the UI will show
# "object storage is not configured". Startup log also warns: [portal files] NOT configured
#
# Space endpoint (include https, no path). Example regions:
#   https://nyc3.digitaloceanspaces.com
#   https://sfo3.digitaloceanspaces.com
#   https://tor1.digitaloceanspaces.com
# DO_SPACES_ENDPOINT=https://nyc3.digitaloceanspaces.com
# DO_SPACES_REGION=us-east-1
# S3 and AWS SDK want a region; any string often works for Spaces, us-east-1 is common
#
# DO_SPACES_BUCKET=your-bucket-name
# Create "Spaces key" in DO → API → Space keys (Access key + secret)
# DO_SPACES_KEY=... 
# DO_SPACES_SECRET=...
#
# (Aliases also supported: S3_ENDPOINT, S3_BUCKET, S3_ACCESS_KEY, S3_SECRET_KEY, S3_REGION)
#
# ── CORS on the BUCKET (browser → direct PUT) ──
# The browser uploads to the presigned URL on your Space. In DigitalOcean: Space → CORS
# (or s3 CORS on the bucket), add something like (replace with your real origins):
#
# [
#   {
#     "AllowedOrigins": [
#       "https://axiomft.ca",
#       "https://www.axiomft.ca",
#       "https://portal.axiomft.ca",
#       "http://localhost:5173"
#     ],
#     "AllowedMethods": [ "GET", "PUT", "POST", "DELETE", "HEAD" ],
#     "AllowedHeaders": [ "Content-Type", "Authorization", "x-amz-acl" ],
#     "ExposeHeaders": [ "ETag" ],
#     "MaxAgeSeconds": 3000
#   }
# ]
#
# If CORS is wrong, upload fails after presign-put with a network / TypeError in the browser
# and the new UI shows a specific message + console.error.
#
# ══ Optional ══
# PORT=3000
# NODE_ENV=development
# PORTAL_STAFF_CLERK_IDS=user_xxx
# PORTAL_MAX_UPLOAD_BYTES=104857600
